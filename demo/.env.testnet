# Default testnet config for `npm run dev` / `npm run build:testnet`.
# Loaded automatically by Vite in testnet mode. Anything you set in
# `.env.testnet.local` (gitignored) overrides this file.
#
# All values below are public — there are no secrets. Don't add any.

# StarkNet Sepolia RPC (direct — `/api/rpc` only works behind the Vercel proxy)
VITE_RPC_URL=http://34.170.198.113:9545/rpc/v0_10
# Discovery service (shared, indexes Sepolia chain — accepts any pool address per request)
VITE_INDEXER_URL=http://35.192.48.142:8080
# Proving service (shared)
VITE_PROVING_SERVICE_URL=http://34.29.249.119:3000

# Chain ID for SN_SEPOLIA
VITE_CHAIN_ID=0x534e5f5345504f4c4941
VITE_EXPLORER_URL=https://sepolia.voyager.online

# Privacy pool — deferred-apply variant, declared + deployed from hackathon/yoni/delayed-proofs.
# To use the original pool instead, override VITE_POOL_ADDRESS / VITE_POOL_CLASS_HASH in
# .env.testnet.local. The deferred-apply variant adds store_actions / apply_stored_actions
# entrypoints; the original pool only has apply_actions and the deferred toggle in the UI
# will revert on chain.
VITE_POOL_ADDRESS=0x05c0ba019e42031f9b6aefa1d154ab53bb14f43f60ea4d5ca32d9c9c879ef143
VITE_POOL_CLASS_HASH=0x6048f9e0979b9d00e31021a206fb0410afeed19b3bc80ae0e1c4ed1bec518e7
VITE_COMPLIANCE_PUBLIC_KEY=0x650017a7a62969b7c5735b5fe5725db27471eda81a57541ffd3c3b92c76cae4
VITE_PROOF_VALIDITY_BLOCKS=450

# Tokens — STRK is the native Sepolia fee token. TST/USD/BTC + vUSD/vBTC are
# the same test tokens the canonical privacy-pool demo uses; they're paired
# against the real Ekubo / Vesu deployments on Sepolia.
VITE_TOKENS=[{"name":"STRK","address":"0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d","decimals":18,"fee":true},{"name":"USD","address":"0x052bc205e18aed1ebc3a6baea9f35a4ff857de12b2cc3a1b8cdfa9da9c147d4d","decimals":18,"mintEntrypoint":"mint"},{"name":"BTC","address":"0x07c382ab3fab30dc425917ebcd36e19c53f2fbfad898cd2ee192ffcd980e0ce5","decimals":18,"mintEntrypoint":"mint"},{"name":"vUSD","address":"0x04ac3fce79e8dcc7f2b206b10219d818861fcc910dacf86d0bff0cad8da24fc0","decimals":18},{"name":"vBTC","address":"0x05cb6f89f2dc65655ddb1d1ae09da86e4f206030b235a419727cfadaeb75d293","decimals":18}]

# Ekubo on Sepolia — real Ekubo deployment. `get_pool_price` works, swaps go
# through the real Core. The USD↔BTC pool is seeded with admin-provided
# liquidity (see DEFERRED_APPLY_DEPLOY.md for the seeding recipe).
VITE_EKUBO_EXECUTOR_ADDRESS=0x038a6dd76bac17c91d4e9fb9231a4783f296890f75a450bf24447cdde702db9d
VITE_EKUBO_CORE_ADDRESS=0x0f77cf9387fb80152e93125c19be1fedee5bddc866c534cea73473e641695d3
VITE_EKUBO_ROUTER_ADDRESS=0x052770067788f8b45b342c0eb970e24e6a1899e7080c113b0dc1e53db43a83b0
# Only USD↔BTC has liquidity on real Ekubo Sepolia (seeded by us).
VITE_EKUBO_POOLS=[{"token0":"0x052bc205e18aed1ebc3a6baea9f35a4ff857de12b2cc3a1b8cdfa9da9c147d4d","token1":"0x07c382ab3fab30dc425917ebcd36e19c53f2fbfad898cd2ee192ffcd980e0ce5","fee":"170141183460469235273462165868118016","tickSpacing":"1000","extension":"0x0","skipAhead":"0"}]

# Vesu lending — real Vesu deployment.
VITE_VESU_LENDING_HELPER_ADDRESS=0x055a92aae47b775e5be91e88fbf24be606935dc9df3ca09db4d4e0f97aa6845f
VITE_VESU={"vaults":[{"token":"USD","vTokenAddress":"0x04ac3fce79e8dcc7f2b206b10219d818861fcc910dacf86d0bff0cad8da24fc0"},{"token":"BTC","vTokenAddress":"0x05cb6f89f2dc65655ddb1d1ae09da86e4f206030b235a419727cfadaeb75d293"}]}

# Privacy-OTC settlement contract (https://github.com/eytan-starkware/Privacy-OTC).
# Implements `join_trade(trade_id, actions)` — atomic peer-to-peer swaps.
# Built locally as `packages/otc_settlement` against this branch's privacy pool.
VITE_OTC_EXECUTOR_ADDRESS=0x056ac8a6faa4166a8e66d66032a2abf4f1567667d3ab4c1e5f0c498a3e7dde60

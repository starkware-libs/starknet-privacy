/// Input for the `UseNote` action.
#[derive(Serde, Copy, Drop, PartialEq, Debug)]
pub struct UseNoteInput {
    /// The channel key of the note's channel.
    pub channel_key: felt252,
    /// The note's token address.
    pub token: ContractAddress,

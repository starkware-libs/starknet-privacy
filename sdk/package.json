{
  "name": "starknet-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK layering custom flows on top of starknet.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && vitest run",
    "test:watch": "vitest watch",
    "check": "npm run test && npm run build",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "starknet",
    "sdk",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "starknet": "^9.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}

# StarkNet RPC endpoint
VITE_RPC_URL=http://localhost:9545/rpc/v0_10
# Discovery service API URL
VITE_INDEXER_URL=http://localhost:8080
# Proving service URL (required for real proofs; if unset, uses mock execute_view)
VITE_PROVING_SERVICE_URL=http://localhost:3000
# Contract addresses
VITE_POOL_ADDRESS=0x0123...
VITE_CHAIN_ID=0x534e5f494e544547524154494f4e5f5345504f4c4941
# Pool deployment
VITE_POOL_CLASS_HASH=0x0abc...
VITE_COMPLIANCE_PUBLIC_KEY=0x0def...
VITE_PROOF_VALIDITY_BLOCKS=450
# JSON array of tokens. Set "fee":true for the gas token, "mintEntrypoint" if different from "permissionedMint".
VITE_TOKENS=[{"name":"STRK","address":"0x...","decimals":18,"fee":true},{"name":"TST","address":"0x...","decimals":18},{"name":"USD","address":"0x...","decimals":18,"mintEntrypoint":"mint"},{"name":"BTC","address":"0x...","decimals":18,"mintEntrypoint":"mint"}]
# All accounts (JSON array). Admin account must have "admin": true.
# Import via the Edit button in the UI, or pass as ?accounts=<base64> query param.
# Example: [{"name":"admin","address":"0x0...","privateKey":"0x0...","viewingKey":"0x0","admin":true},{"name":"Alice","address":"0x0...","privateKey":"0x0...","viewingKey":"0x0..."}]

# Real backend URLs (optional — when set, OHTTP uses these as gateway and VITE_INDEXER_URL / VITE_PROVING_SERVICE_URL as relay)
# VITE_BACKEND_INDEXER_URL=http://indexer-host:8080
# VITE_BACKEND_PROVER_URL=http://prover-host:3000
# Pinned OHTTP key config (base64). When set, skips fetching /ohttp-keys at runtime.
# VITE_OHTTP_KEY_CONFIG=ACkAACBBhSMg/zZ0lfpSLJTLg685Hk6JAYOSclu/IJjdkxvEJAAEAAEAAQ==

# Gateway endpoints (optional — health indicators shown when set)
VITE_GATEWAY_URL=/api/gateway
VITE_FEEDER_GATEWAY_URL=https://feeder.privacy-starknet-integration-fgw.starknet.io

# Ekubo swap (optional — all VITE_EKUBO_* vars required if VITE_EKUBO_EXECUTOR_ADDRESS is set)
VITE_EKUBO_EXECUTOR_ADDRESS=0x...
VITE_EKUBO_CORE_ADDRESS=0x...
VITE_EKUBO_ROUTER_ADDRESS=0x...
# Pool key + params as JSON. token0/token1 must match addresses in VITE_TOKENS.
VITE_EKUBO_POOL={"token0":"0x...","token1":"0x...","fee":"170141183460469235273462165868118016","tickSpacing":"1000","extension":"0x0","skipAhead":"0"}

# Vesu lending (optional — all VITE_VESU_* vars required if VITE_VESU_LENDING_HELPER_ADDRESS is set)
VITE_VESU_LENDING_HELPER_ADDRESS=0x...
# Vaults as JSON. Token names must match entries in VITE_TOKENS.
VITE_VESU={"vaults":[{"token":"USD","vTokenAddress":"0x..."},{"token":"BTC","vTokenAddress":"0x..."}]}

# Paymaster (optional — enables gasless transactions via AVNU paymaster)
VITE_PAYMASTER_URL=
VITE_PAYMASTER_FEE_TOKEN=
VITE_AVNU_API_KEY=

# StarkNet RPC endpoint
VITE_RPC_URL=http://localhost:9545/rpc/v0_10
# Discovery service API URL
VITE_INDEXER_URL=http://localhost:8080
# Proving service URL (required for real proofs; if unset, uses mock execute_view)
VITE_PROVING_SERVICE_URL=http://localhost:3000
# Contract addresses
VITE_POOL_ADDRESS=0x0123...
VITE_TOKEN_ADDRESS=0x0456...
VITE_FEE_TOKEN_ADDRESS=0x0789...
VITE_CHAIN_ID=0x534e5f494e544547524154494f4e5f5345504f4c4941
# Pool deployment
VITE_POOL_CLASS_HASH=0x0abc...
VITE_COMPLIANCE_PUBLIC_KEY=0x0def...
VITE_PROOF_VALIDITY_BLOCKS=450
# Admin account for minting
VITE_ADMIN_ADDRESS=0x0aaa...
VITE_ADMIN_KEY=0x0bbb...
# JSON array of accounts: [{"name":"Alice","address":"0x...","privateKey":"0x...","viewingKey":"0x..."}]
VITE_ACCOUNTS=[{"name":"Alice","address":"0x0...","privateKey":"0x0...","viewingKey":"0x0..."}]

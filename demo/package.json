{
  "name": "starknet-privacy-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode testnet",
    "dev:mainnet": "vite --mode mainnet",
    "build": "tsc -b && vite build",
    "build:testnet": "tsc -b && vite build --mode testnet",
    "build:mainnet": "tsc -b && vite build --mode mainnet",
    "preview": "vite preview",
    "preview:mainnet": "vite preview --mode mainnet",
    "pull-env": "bash scripts/pull-env.sh",
    "lint": "prettier --check src/ && eslint src/ && tsc --noEmit",
    "format": "prettier --write src/ && eslint --fix src/"
  },
  "dependencies": {
    "get-starknet": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "starknet": "10.0.0-beta.6",
    "starknet-sdk": "file:../sdk"
  },
  "overrides": {
    "starknet": "$starknet",
    "rollup": ">=4.59.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^6.3.5"
  }
}

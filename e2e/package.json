{
  "name": "starknet-privacy-e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:e2e": "vitest run",
    "test:devnet": "vitest run tests/devnet",
    "test:integration": "vitest run tests/integration",
    "scarb:build": "cd .. && SCARB_IGNORE_CAIRO_VERSION=true scarb build -p privacy -p vesu_lending_helper",
    "scarb:build:vesu": "cd vesu-contracts && asdf exec scarb build",
    "build:contracts": "npm run scarb:build && npm run scarb:build:vesu",
    "batch-operations": "tsx --env-file=.env scripts/batch-operations.ts",
    "declare-class": "tsx --env-file=.env scripts/declare-class.ts",
    "deploy-accounts": "tsx --env-file=.env scripts/deploy-accounts.ts",
    "load-test-discovery": "tsx --env-file=.env scripts/load-test-discovery.ts",
    "generate-dump": "tsx scripts/generate-dump.ts",
    "pull-env": "tsx scripts/pull-env.ts",
    "setup-tokens": "tsx --env-file=.env scripts/setup-tokens.ts",
    "setup-vesu": "tsx --env-file=.env scripts/setup-vesu.ts",
    "setup-vesu-helper": "tsx --env-file=.env scripts/setup-vesu-helper.ts",
    "lint": "eslint src tests scripts --fix",
    "lint:check": "eslint src tests scripts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "starknet": "10.0.0-beta.6",
    "@starkware-libs/starknet-privacy-sdk": "file:../sdk"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.15"
  }
}

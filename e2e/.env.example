# RPC endpoints (Sepolia)
VITE_RPC_URL=http://localhost:9545/rpc/v0_10
VITE_WS_URL=ws://localhost:9545/ws/rpc/v0_8

# ERC-20 token contract address
VITE_TOKEN_ADDRESS=0x0

# Chain ID (hex-encoded felt, e.g. SN_SEPOLIA)
VITE_CHAIN_ID=0x534e5f5345504f4c4941

# Compliance public key
VITE_COMPLIANCE_PUBLIC_KEY=0x0

# Pre-deployed privacy pool address (for stress tests that skip deployment)
VITE_POOL_ADDRESS=0x0

# Pre-declared pool class hash (update after running declare-class)
VITE_POOL_CLASS_HASH=0x0

# Proving service URL
VITE_PROVING_SERVICE_URL=http://localhost:8080

# Indexer URL
VITE_INDEXER_URL=http://localhost:3000

# All accounts (JSON array). Admin account must have "admin": true.
# Each entry: name, address, privateKey, viewingKey, salt, admin (optional)
ACCOUNTS=[{"name":"admin","address":"0x0","privateKey":"0x0","viewingKey":"0x0","salt":"0x0","admin":true},{"name":"alice","address":"0x0","privateKey":"0x0","viewingKey":"0x0","salt":"0x0"}]

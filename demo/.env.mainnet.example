# Mainnet config for the privacy-pool demo. Copy to `.env.mainnet.local` and
# fill in the TODOs. Load with `npm run dev:mainnet`.
#
# Security: NEVER put a private key in any VITE_* var — every VITE_* value
# ships in the public JS bundle. The app treats VITE_CHAIN_ID=SN_MAIN as a
# signal to lock down: accounts stay in tab memory only (no localStorage),
# the `?accounts=` share URL is gone, OHTTP is enforced, and the transparent
# mint flow is hidden (no admin in this profile).

# StarkNet mainnet RPC endpoint
VITE_RPC_URL=TODO_MAINNET_RPC_URL
# Discovery service URL (OHTTP gateway recommended for privacy)
VITE_INDEXER_URL=TODO_MAINNET_INDEXER_URL
# Proving service URL (required for real proofs)
VITE_PROVING_SERVICE_URL=TODO_MAINNET_PROVER_URL

# Pool deployment
VITE_POOL_ADDRESS=TODO_MAINNET_POOL_ADDRESS
VITE_POOL_CLASS_HASH=TODO_MAINNET_POOL_CLASS_HASH
VITE_COMPLIANCE_PUBLIC_KEY=TODO_MAINNET_COMPLIANCE_PUBLIC_KEY
VITE_PROOF_VALIDITY_BLOCKS=450

# Mainnet chain id (SN_MAIN). Triggers the mainnet lockdown described above.
VITE_CHAIN_ID=0x534e5f4d41494e

# JSON array of mainnet tokens. Set "fee":true for the gas token.
VITE_TOKENS=TODO_MAINNET_TOKENS_JSON

# Pinned OHTTP key config (base64). Strongly recommended for public deploys —
# skips runtime fetch of /ohttp-keys (otherwise a TOFU risk).
# VITE_OHTTP_KEY_CONFIG=

# Optional backend gateway URLs (enable OHTTP relay mode)
# VITE_BACKEND_INDEXER_URL=
# VITE_BACKEND_PROVER_URL=

VITE_GATEWAY_URL=/api/gateway
VITE_FEEDER_GATEWAY_URL=TODO_MAINNET_FEEDER_GATEWAY_URL

# Block explorer (for linking tx hashes)
VITE_EXPLORER_URL=https://starkscan.co

# DeFi integrations (optional) — set only if the helpers are deployed on
# mainnet and you want to expose the DeFi tab.
# VITE_EKUBO_EXECUTOR_ADDRESS=
# VITE_EKUBO_CORE_ADDRESS=
# VITE_EKUBO_ROUTER_ADDRESS=
# VITE_EKUBO_POOLS=[{"token0":"0x...","token1":"0x...","fee":"0x...","tickSpacing":"...","extension":"0x0","skipAhead":"0"}, ...]
# VITE_VESU_LENDING_HELPER_ADDRESS=
# VITE_VESU={"vaults":[...]}

# Paymaster: the mint flow is disabled on mainnet (no admin account), but
# paymaster-sponsored deposits/withdrawals/transfers still work if configured.
# VITE_PAYMASTER_URL=
# VITE_PAYMASTER_FEE_TOKEN=
# VITE_AVNU_API_KEY=

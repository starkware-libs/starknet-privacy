# RPC endpoints (integration Sepolia)
RPC_URL=http://localhost:9545/rpc/v0_10
WS_URL=ws://localhost:9545/ws/rpc/v0_8

# Chain ID (hex-encoded felt, e.g. SN_INTEGRATION_SEPOLIA)
CHAIN_ID=0x534e5f494e544547524154494f4e5f5345504f4c4941

# Compliance public key
COMPLIANCE_PUBLIC_KEY=0x0

# Pre-deployed privacy pool address (for stress tests that skip deployment)
POOL_ADDRESS=0x0

# Accounts (JSON array with name, address, privateKey, viewingKey)
ACCOUNTS=[{"name":"admin","address":"0x0","privateKey":"0x0","viewingKey":"0x0"},{"name":"alice","address":"0x0","privateKey":"0x0","viewingKey":"0x0"}]

# Deploy salt seed — change to deploy fresh contract instances at new addresses
DEPLOY_SALT_SEED=0x0

# Token addresses (filled by `npm run deploy-vesu`)
USD_TOKEN_ADDRESS=0x0
BTC_TOKEN_ADDRESS=0x0

# Ekubo addresses (filled by `npm run deploy-ekubo`)
EKUBO_CORE_ADDRESS=0x0
EKUBO_ROUTER_ADDRESS=0x0
EKUBO_POSITIONS_ADDRESS=0x0
EKUBO_POOL_TOKEN0=0x0
EKUBO_POOL_TOKEN1=0x0
EKUBO_POOL_FEE=0
EKUBO_TICK_SPACING=1
EKUBO_EXTENSION=0x0
EKUBO_SKIP_AHEAD=0
EXECUTOR_ADDRESS=0x0

# Ekubo pool seeding params (optional overrides for `npm run deploy-ekubo`)
EKUBO_POOL_INITIAL_TICK=0
EKUBO_SEED_AMOUNT0=0
EKUBO_SEED_AMOUNT1=0
EKUBO_POSITION_LOWER_BOUND=0
EKUBO_POSITION_UPPER_BOUND=0

# Vesu addresses (filled by `npm run deploy-vesu`)
VESU_POOL_FACTORY_ADDRESS=0x0
VESU_POOL_ADDRESS=0x0
VESU_ORACLE_ADDRESS=0x0
USD_VTOKEN_ADDRESS=0x0
BTC_VTOKEN_ADDRESS=0x0
VESU_LENDING_HELPER_ADDRESS=0x0

# Demo app integration (filled by deploy scripts into .env.deployed)
VITE_TOKENS=[{"name":"USD","address":"0x0","decimals":18},{"name":"BTC","address":"0x0","decimals":18}]
VITE_VESU_LENDING_HELPER_ADDRESS=0x0
VITE_VESU={"vaults":[{"token":"USD","vTokenAddress":"0x0"},{"token":"BTC","vTokenAddress":"0x0"}]}
VITE_EKUBO_EXECUTOR_ADDRESS=0x0
VITE_EKUBO_CORE_ADDRESS=0x0
VITE_EKUBO_ROUTER_ADDRESS=0x0
VITE_EKUBO_POOL={"token0":"0x0","token1":"0x0","fee":"0","tickSpacing":"1","extension":"0x0","skipAhead":"0"}
